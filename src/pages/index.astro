---
import Base from "../layouts/Base.astro";
import { SITE, SERVICES, AREAS, NEIGHBORHOODS, ROADS, itemListNode, faqNode } from "../lib/site.js";
const tel = "tel:" + SITE.phoneTel;
const faqs = [
  { q: "How fast can a tow truck reach me in Anna?", a: "Anna is a compact town, so a local operator is usually only minutes away. Most of Anna sits within a short run of US-75 and FM-455, and once you call we give you a time estimate based on where you are and current traffic." },
  { q: "Do you cover my Anna neighborhood?", a: "Yes. Coverage runs across every Anna subdivision, including West Crossing, Villages of Hurricane Creek, Anna Town Square, Anna Crossing, Lakeview, Avery Pointe, and the newer phases out toward Rosamond Parkway and Ferguson Parkway." },
  { q: "What does a tow cost in Anna?", a: "Price depends on the vehicle, the distance, and the type of help you need. You get an upfront estimate over the phone before any truck rolls, so there are no surprises when help arrives." },
  { q: "Are you available at night and on weekends?", a: "Yes. Dispatch runs 24 hours a day, 7 days a week, including holidays. A breakdown at 2 a.m. on US-75 gets the same response as one at noon." },
  { q: "Which towns near Anna do you serve?", a: "Beyond Anna itself, coverage reaches Melissa, McKinney, Van Alstyne, Celina, and Princeton, plus the smaller communities in between along the US-75 corridor." },
  { q: "What kinds of vehicles can you tow?", a: "Cars, pickups, SUVs, vans, and motorcycles are all handled on a flatbed or wheel-lift. Tell us the make and situation when you call and the right truck is sent." },
];
const schema = [itemListNode(SERVICES), faqNode(faqs)];
---
<Base
  title="Anna Towing | 24/7 Tow Truck & Roadside Help in Anna, TX"
  description="Local 24/7 towing, vehicle recovery, and roadside assistance across Anna, TX 75409. Fast tow trucks to every Anna neighborhood and the nearby Collin County towns. Call (214) 491-5215."
  path="/"
  schema={schema}
>
  <section class="hero"><div class="wrap">
    <div class="hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Anna, TX · 75409 · Open 24/7</p>
        <h1>Anna's hometown tow truck, minutes from your driveway</h1>
        <p class="lede">Broken down on US-75, stuck off FM-455, or need a tow from your own street? One call puts a local Anna operator on the way, day or night.</p>
        <div class="hero-cta">
          <a class="btn btn-call btn-lg" href={tel}><svg><use href="#i-phone"/></svg> Call {SITE.phoneDisplay}</a>
          <a class="btn btn-ghost btn-lg" href="/services/">See Services</a>
        </div>
        <div class="trust-row">
          <span><svg><use href="#i-clock"/></svg> 24/7, day or night</span>
          <span><svg><use href="#i-pin"/></svg> Every Anna neighborhood</span>
          <span><svg><use href="#i-shield"/></svg> Licensed &amp; insured</span>
        </div>
      </div>

      <div class="nbhd-card">
        <div class="nc-head"><b>Serving all of Anna</b><span class="mono-tiny">75409</span></div>
        <div class="nc-body">
          <svg class="townmap" viewBox="0 0 400 232" role="img" aria-label="Stylized map of Anna, Texas showing US-75, FM-455, and neighborhoods">
            <rect width="400" height="232" fill="#E6EEE6"/>
            <g stroke="#C9D8C7" stroke-width="1"><path d="M0 58H400"/><path d="M0 116H400"/><path d="M0 174H400"/><path d="M80 0V232"/><path d="M160 0V232"/><path d="M240 0V232"/><path d="M320 0V232"/></g>
            <!-- US-75 -->
            <path d="M150 0 V232" stroke="#1F5A38" stroke-width="9"/>
            <path d="M150 0 V232" stroke="#7FCF9A" stroke-width="1.6" stroke-dasharray="7 9"/>
            <!-- SH-5 -->
            <path d="M212 0 V232" stroke="#2E6E48" stroke-width="5"/>
            <!-- FM-455 -->
            <path d="M0 120 H400" stroke="#C2632F" stroke-width="7"/>
            <!-- Rosamond / Ferguson connectors -->
            <path d="M0 70 H150" stroke="#B9A789" stroke-width="3"/>
            <path d="M212 168 H400" stroke="#B9A789" stroke-width="3"/>
            <!-- shields -->
            <g font-family="Red Hat Mono, monospace" font-weight="600">
              <rect x="138" y="8" width="24" height="18" rx="3" fill="#1F5A38"/><text x="150" y="21" fill="#fff" font-size="11" text-anchor="middle">75</text>
              <rect x="300" y="104" width="28" height="17" rx="3" fill="#C2632F"/><text x="314" y="117" fill="#fff" font-size="10" text-anchor="middle">455</text>
              <rect x="200" y="8" width="22" height="18" rx="3" fill="#2E6E48"/><text x="211" y="21" fill="#fff" font-size="11" text-anchor="middle">5</text>
            </g>
            <!-- neighborhood pins -->
            <g>
              <circle cx="96" cy="92" r="6" fill="#C2632F"/><text x="106" y="96" font-family="Albert Sans, sans-serif" font-size="11" fill="#211E18">West Crossing</text>
              <circle cx="98" cy="150" r="6" fill="#C2632F"/><text x="108" y="154" font-family="Albert Sans, sans-serif" font-size="11" fill="#211E18">Hurricane Creek</text>
              <circle cx="250" cy="92" r="6" fill="#C2632F"/><text x="260" y="96" font-family="Albert Sans, sans-serif" font-size="11" fill="#211E18">Town Square</text>
              <circle cx="252" cy="150" r="6" fill="#C2632F"/><text x="262" y="154" font-family="Albert Sans, sans-serif" font-size="11" fill="#211E18">Anna Crossing</text>
              <!-- Anna star -->
              <path d="M181 116 l3.2 6.8 7.4 .9 -5.5 5 1.4 7.3 -6.5 -3.6 -6.5 3.6 1.4 -7.3 -5.5 -5 7.4 -.9z" fill="#1F5A38"/>
            </g>
          </svg>
          <ul class="nbhd-list">
            {NEIGHBORHOODS.slice(0, 6).map((n) => (
              <li><svg><use href="#i-check"/></svg>{n}</li>
            ))}
          </ul>
          <div class="nc-foot">
            <span class="mono-tiny">US-75 · FM-455 · SH-5 · Rosamond Pkwy</span>
            <a href={tel}>Call now &#8594;</a>
          </div>
        </div>
      </div>
    </div>
  </div></section>

  <div class="localstrip"><div class="wrap">
    <b>Minutes from</b>
    <span>Slayter Creek Park</span><span class="sep">·</span>
    <span>Natural Springs Park</span><span class="sep">·</span>
    <span>Anna Town Square</span><span class="sep">·</span>
    <span>Anna High School</span><span class="sep">·</span>
    <span>US-75 &amp; FM-455</span>
  </div></div>

  <section><div class="wrap">
    <div class="sec-head"><p class="eyebrow">What we do</p><h2>Towing and roadside help for Anna drivers</h2><p>Six core services, every one dispatched from right here in the Anna area so help does not have to drive in from Dallas.</p></div>
    <div class="svc-grid">
      {SERVICES.map((s) => (
        <a class="svc-card" href={s.url}>
          <div class="svc-ic"><svg><use href={"#" + s.icon}/></svg></div>
          <span class="svc-klass">{s.klass}</span>
          <h3>{s.name}</h3>
          <p>{s.blurb}</p>
          <span class="svc-more">Learn more <svg><use href="#i-arrow"/></svg></span>
        </a>
      ))}
    </div>
  </div></section>

  <section class="pine-band"><div class="wrap">
    <div class="dir-grid">
      <div>
        <p class="eyebrow">Hometown coverage</p>
        <h2>We roll to every Anna neighborhood</h2>
        <p style="color:#D6E4D7;max-width:42ch">From the established streets of West Crossing to the newest phases out in the Villages of Hurricane Creek and Anna Town Square, a local operator knows the way without a map app.</p>
        <div class="nbhd-tags">
          {NEIGHBORHOODS.map((n) => (<span>{n}</span>))}
        </div>
      </div>
      <div>
        <p class="eyebrow">The roads that connect them</p>
        <ul class="road-list">
          {ROADS.map((r) => (<li><span class="rd">{r.road}</span><span class="rn">{r.note}</span></li>))}
        </ul>
      </div>
    </div>
  </div></section>

  <section class="tint"><div class="wrap">
    <div class="sec-head center"><p class="eyebrow" style="justify-content:center">How a call works</p><h2>Simple, local, and fast</h2></div>
    <div class="steps">
      <div class="step"><h3>Call and tell us where</h3><p>A US-75 exit, an address off FM-455, or just your subdivision. Tell us what the vehicle is doing and we take it from there.</p></div>
      <div class="step"><h3>A local operator rolls</h3><p>The nearest available Anna tow operator heads out with the right truck and gives you an honest time estimate.</p></div>
      <div class="step"><h3>Hooked up and home</h3><p>Your vehicle is loaded with care and taken where you want it, a shop in McKinney, your driveway, or anywhere close by.</p></div>
    </div>
  </div></section>

  <section><div class="wrap">
    <div class="split">
      <div class="prose">
        <p class="eyebrow">Local to Anna</p>
        <h2>A tow company that actually knows Anna</h2>
        <p class="lead-p">Anna has grown fast, and the roads have grown with it. A local operator keeps up with all of it.</p>
        <p>When you are stranded, the last thing you want is a truck crawling up Central Expressway from the city while you wait on the shoulder. Calling Anna Towing connects you with a tow operator who already works this town, who knows that FM-455 turns into West White Street and East White Street, that Rosamond Parkway runs past Anna High School, and that the Villages of Hurricane Creek sit on the west side off Ferguson Parkway.</p>
        <p>That local knowledge shows up as a shorter wait. Whether you are parked at Slayter Creek Park, stuck at a light on SH-5, or sitting in a driveway in Avery Pointe with a car that will not start, help comes from nearby and gets to you quickly.</p>
        <p>Every job is handled by a licensed and insured local operator, with an upfront estimate before any truck rolls. No pressure, no runaround, just a straight answer and a tow truck on the way.</p>
        <a class="btn btn-pine btn-lg" href="/about-anna-towing-company/">More about us <svg style="width:1.1em;height:1.1em;fill:none;stroke:currentColor"><use href="#i-arrow"/></svg></a>
      </div>
      <div class="media"><img src="/images/hero-recovery.webp" alt="Flatbed tow truck loading a sedan on a quiet Anna, TX street at dusk" width="1200" height="675" loading="lazy" /></div>
    </div>
  </div></section>

  <section class="tint"><div class="wrap">
    <div class="sec-head"><p class="eyebrow">Beyond Anna</p><h2>Nearby Collin County towns we cover</h2><p>Anna sits in the middle of a fast-growing stretch of US-75. Coverage reaches the towns right around it.</p></div>
    <div class="area-grid">
      {AREAS.map((a) => (
        <a class="area-card" href={a.url}>
          <span class="pin"><svg><use href="#i-pin"/></svg></span>
          <span><b>{a.name}, TX</b><span class="mono-tiny">Towing &amp; roadside</span></span>
        </a>
      ))}
    </div>
  </div></section>

  <section><div class="wrap">
    <div class="sec-head center"><p class="eyebrow" style="justify-content:center">Why neighbors call</p><h2>What you get with a local call</h2></div>
    <div class="feature-grid">
      <div class="feat"><span class="fi"><svg><use href="#i-clock"/></svg></span><div><h3>Around-the-clock dispatch</h3><p>Day, night, weekend, or holiday, the phone is answered and a truck is sent. Breakdowns do not keep business hours.</p></div></div>
      <div class="feat"><span class="fi"><svg><use href="#i-pin"/></svg></span><div><h3>Anna roads, memorized</h3><p>A local operator knows the shortcuts, the new subdivisions, and which US-75 exit gets to you fastest.</p></div></div>
      <div class="feat"><span class="fi"><svg><use href="#i-shield"/></svg></span><div><h3>Licensed and insured</h3><p>Your vehicle is handled by a properly licensed and insured local operator, loaded and secured the right way.</p></div></div>
      <div class="feat"><span class="fi"><svg><use href="#i-bolt"/></svg></span><div><h3>Upfront estimates</h3><p>You hear the price before a truck rolls. No surprise add-ons once help shows up at your door.</p></div></div>
    </div>
  </div></section>

  <section class="tint"><div class="wrap">
    <div class="sec-head center"><p class="eyebrow" style="justify-content:center">Questions</p><h2>Anna towing FAQ</h2></div>
    <div class="faq-list">
      {faqs.map((f) => (<details class="faq-item"><summary>{f.q}</summary><p>{f.a}</p></details>))}
    </div>
  </div></section>

  <section class="callband"><div class="wrap">
    <h2>One call. A tow truck on the way.</h2>
    <p>Towing, recovery, and roadside help across Anna, TX and the nearby towns, 24 hours a day, 7 days a week.</p>
    <a class="btn btn-call btn-lg" href={tel}><svg><use href="#i-phone"/></svg> Call {SITE.phoneDisplay}</a>
  </div></section>
</Base>
